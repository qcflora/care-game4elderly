      ]
    },
    {
      "id": "li_act3_d25_001",
      "characterId": "li_bobo",
      "act": 3,
      "day": 25,
      "type": "choice",
      "scene": "shoe_store",
      "illustrationId": "li_shoe_choice",
      "dialogues": [
        {
          "id": "dlg_113",
          "speaker": "narrator",
          "speakerName": "",
          "text": "为了配合足部护理，李伯伯需要换双合适的鞋。他看上一双皮面硬底的老头鞋，说'穿了一辈子这种鞋，踏实'。可这双鞋鞋腔偏窄、内里有接缝。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_114",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "糖尿病患者的鞋有讲究——选错鞋是糖尿病足的头号诱因。怎么帮要强又念旧的李伯伯选对鞋，还不伤他面子？",
          "layer": "essential",
          "emotion": "thoughtful"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "直接说这鞋不适合糖尿病人，让他换运动鞋",
          "description": "明确否定",
          "isCorrect": false,
          "effects": [
            {
              "type": "trust",
              "delta": -4,
              "reason": "又被否定"
            },
            {
              "type": "mood",
              "delta": -3,
              "reason": "面子受损"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act3_d25_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "他又不是不懂道理，是不愿被'指挥'。直接否定他选的鞋，他会觉得'连穿什么鞋都管'。",
            "explanation": "对要强的老人，'否定+命令'最无效。应提供信息和选择权，让他自己得出结论。"
          }
        },
        {
          "id": "choice_b",
          "text": "夸他有眼光，再请教式地聊起'糖尿病人选鞋有门道'，让他自己判断",
          "description": "肯定+信息+自主判断",
          "isCorrect": true,
          "effects": [
            {
              "type": "health",
              "delta": 7,
              "reason": "选对鞋预防足部损伤"
            },
            {
              "type": "trust",
              "delta": 6,
              "reason": "被尊重又被科普"
            },
            {
              "type": "mood",
              "delta": 4,
              "reason": "面子保住了"
            }
          ],
          "spiritPowerChange": 10,
          "nextNode": "li_act3_d25_002",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "漂亮！先肯定他的眼光，再用'请教'姿态引入知识，最后让他自己判断。李伯伯是工程师，给他数据和道理，他自己会做对选择。",
            "explanation": "糖尿病患者选鞋四原则：1.圆头宽腔不挤脚；2.软面透气无硬接缝；3.鞋垫可拆卸便于检查；4.系带或魔术贴可调节松紧。新鞋第一天穿不超过2小时，逐步适应。老人自主选择+科学信息=最佳配合。"
          }
        },
        {
          "id": "choice_c",
          "text": "由着他买，穿了不舒服自然会换",

      ],
      "devNote": "糖尿病足预防教学"
    },
    {
      "id": "li_act3_d24_002",
      "characterId": "li_bobo",
      "act": 3,
      "day": 24,
      "type": "dayEnd",
      "scene": "bathroom",
      "illustrationId": "li_foot_check_habit",
      "dialogues": [
        {
          "id": "dlg_111",
          "speaker": "elder",
          "speakerName": "李伯伯",
          "text": "（举着镜子看脚底）这玩意儿……还真照出个小水泡。要不是你说，我都没感觉。",
          "layer": "essential",
          "emotion": "surprised"
        },
        {
          "id": "dlg_112",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "看，他已经发现了一个早期问题。这就是自查的价值——在它变成大问题之前，先看见它。",
          "layer": "emotional",
          "emotion": "proud",
          "typingSpeed": 40
        }
      ],

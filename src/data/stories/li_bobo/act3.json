          "typingSpeed": 30
        },
        {
          "id": "dlg_118",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "运动过量的反弹效应：剧烈运动触发应激激素，血糖反而升高。这是糖尿病运动的反直觉知识点。怎么纠正他的'多运动=多降糖'误区？",
          "layer": "essential",
          "emotion": "concerned"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "告诉他运动越多越好是错的，要按医生说的量来",
          "description": "纠正+定标准",
          "isCorrect": false,
          "effects": [
            {
              "type": "trust",
              "delta": -3,
              "reason": "又被纠正"

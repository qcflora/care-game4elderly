  "nodes": [
    {
      "id": "li_act3_d22_001",
      "characterId": "li_bobo",
      "act": 3,
      "day": 22,
      "type": "choice",
      "scene": "park",
      "illustrationId": "li_morning_dizzy",
      "dialogues": [
        {
          "id": "dlg_100",
          "speaker": "narrator",
          "speakerName": "",
          "text": "清晨公园，李伯伯照常快走，今天却比平时走得急——昨晚聚会多吃了点，想'走回来'。走到一半，他突然冒冷汗、手抖、腿发软，扶住了栏杆。智能手表心率警报响了。",
          "layer": "essential",
          "duration": 4500,
          "typingSpeed": 30
        },
        {
          "id": "dlg_101",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "冷汗、手抖、腿软、运动中突发——这是低血糖的典型前兆！李伯伯今早没吃东西就空腹快走，昨晚又吃得杂。怎么判断和处理？",
          "layer": "essential",
          "emotion": "urgent"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "让他坚持走完，出出汗就好了",
          "description": "误以为是劳累",
          "isCorrect": false,
          "effects": [
            {
              "type": "health",
              "delta": -8,
              "reason": "低血糖持续恶化，可能昏迷"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act3_d22_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "危险！运动会加速血糖消耗，低血糖时继续运动可能直接昏迷。这是严重错误。",
            "explanation": "低血糖急救第一原则：立即停止运动！运动消耗葡萄糖，会让低血糖雪上加霜。糖尿病早期患者运动前必须测血糖，低于5.6mmol/L应先补充碳水。"
          }
        },
        {
          "id": "choice_b",
          "text": "立即让他停下休息，吃随身带的糖果",
          "description": "识别低血糖，正确处置",
          "isCorrect": true,
          "effects": [
            {
              "type": "health",
              "delta": 8,
              "reason": "低血糖及时纠正"
            },
            {
              "type": "trust",
              "delta": 6,
              "reason": "危急时刻被正确守护"
            }
          ],
          "spiritPowerChange": 15,
          "nextNode": "li_act3_d22_002",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "做得好！停运动+补糖是低血糖急救的标准操作。李伯伯随身带糖的习惯（我们前期建立过的）这次救了他。",
            "explanation": "低血糖识别三联征：冷汗+手抖+心慌/腿软。处置：1.立即停止活动坐下；2.补充15g快糖（3-4块硬糖/半杯果汁/葡萄糖片）；3.15分钟后复测，未缓解再补一次。"
          }
        },
        {
          "id": "choice_c",
          "text": "赶紧送他去医院",
          "description": "过度反应",
          "isCorrect": false,
          "effects": [
            {
              "type": "health",
              "delta": -3,
              "reason": "送医途中延误补糖"
            },
            {
              "type": "mood",
              "delta": -3,
              "reason": "小题大做让他丢面子"
            }
          ],
          "spiritPowerChange": 2,
          "nextNode": "li_act3_d22_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "轻度低血糖现场补糖即可，不必送医。送医途中反而耽误补糖，还让要强的李伯伯觉得'小题大做'。",
            "explanation": "低血糖分级处理：轻度（清醒能进食）→现场补糖；中度（意识模糊）→葡萄糖凝胶涂口腔黏膜；重度（昏迷）→立即120+ glucagon注射。判断等级再决定。"
          }
        }
      ],
      "props": [
        {
          "propId": "smartwatch_alert",
          "layer": "display",
          "autoShow": true
        }
      ],
      "tags": [
        "choice",
        "emergency",
        "hypoglycemia",
        "timed-prep"
      ],
      "devNote": "低血糖前兆识别，为Day23限时决策做铺垫"
    },
    {
      "id": "li_act3_d22_002",
      "characterId": "li_bobo",
      "act": 3,
      "day": 22,
      "type": "dayEnd",
      "scene": "park",
      "illustrationId": "li_recovering",
      "dialogues": [
        {
          "id": "dlg_102",
          "speaker": "elder",
          "speakerName": "李伯伯",
          "text": "（缓过来后，有些后怕）……刚才差点栽那儿。幸亏兜里有糖。这低血糖，比高血糖还吓人。",
          "layer": "essential",
          "emotion": "shaken"
        },
        {
          "id": "dlg_103",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "他第一次真切感到'身体会出状况'。这是危机，也是教育契机。明天还有更大的考验。",
          "layer": "emotional",
          "emotion": "concerned",
          "typingSpeed": 40
        }
      ],
      "tags": [
        "day-end"
      ]
    },
    {
      "id": "li_act3_d23_001",
      "characterId": "li_bobo",
      "act": 3,
      "day": 23,
      "type": "event",
      "nextNode": "li_act3_d23_002",
      "scene": "living_room",
      "illustrationId": "li_hypoglycemia_emergency",
      "dialogues": [
        {
          "id": "dlg_104",
          "speaker": "narrator",
          "speakerName": "",
          "text": "上午十点，李伯伯在家测血糖——3.2mmol/L。他本想自己处理，可突然视线模糊、说话含糊，手里的血糖仪掉在地上。老伴吓坏了，给你打电话喊救命。",
          "layer": "essential",
          "duration": 3500,
          "typingSpeed": 30
        },
        {
          "id": "dlg_105",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "中重度低血糖！意识开始模糊，必须30秒内做出正确决策！这是限时关卡，请快速选择！",
          "layer": "essential",
          "emotion": "urgent"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "让他喝杯糖水，观察观察再说",
          "description": "现场补糖，自行处理",
          "isCorrect": false,
          "effects": [
            {
              "type": "health",
              "delta": -8,
              "reason": "意识模糊有误吸风险，自行喂食危险"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act3_d23_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "危险！意识模糊的人喂食/喂水极易误吸入肺，引发窒息或吸入性肺炎，比低血糖本身更致命。",
            "explanation": "低血糖处置铁律：意识模糊/昏迷者绝对禁止经口喂食喂水！误吸是致死性并发症。应侧卧位防误吸+立即拨打120+有条件则注射glucagon（胰高血糖素）。"
          }
        },
        {
          "id": "choice_b",
          "text": "让他侧卧，立即拨打120，准确报告情况和用药史",
          "description": "正确急救+呼叫专业救援",
          "isCorrect": true,
          "effects": [
            {
              "type": "health",
              "delta": 8,
              "reason": "正确急救避免误吸，及时获救"
            },
            {
              "type": "trust",
              "delta": 8,
              "reason": "危急时刻的专业守护"
            }
          ],
          "spiritPowerChange": 15,
          "nextNode": "li_act3_d23_002",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "完美处置！侧卧防误吸+立即120+准确报告，这是中重度低血糖的标准急救流程。你的冷静救了李伯伯。",
            "explanation": "拨打120要点：1.准确地址；2.症状（意识模糊、血糖3.2）；3.用药史（二甲双胍）；4.现场已采取的措施（侧卧位）。120调度员可远程指导。侧卧位=复苏体位，防舌后坠和误吸。"
          }
        },
        {
          "id": "choice_c",
          "text": "直接背他往社区医院跑",
          "description": "自行送医",
          "isCorrect": false,
          "effects": [
            {
              "type": "health",
              "delta": -5,
              "reason": "搬运途中颠簸+无专业监护，风险高"
            }
          ],
          "spiritPowerChange": 2,
          "nextNode": "li_act3_d23_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "意识模糊者搬动风险大，途中无急救设备。不如原地侧卧等120，专业的事交给专业的人。",
            "explanation": "急救原则：除非现场有即时危险（如火灾），意识障碍者不宜自行搬动。等待专业急救人员到场更安全。提前打电话让120带glucagon，比自行送医快。"
          }
        }
      ],
      "tags": [
        "choice",
        "emergency",
        "timed-decision",
        "hypoglycemia",
        "call-120"
      ],
      "devNote": "Day23限时决策节点（30秒），低血糖急症急救教学"
    },
    {
      "id": "li_act3_d23_002",
      "characterId": "li_bobo",
      "act": 3,
      "day": 23,
      "type": "narrative",
      "scene": "hospital",
      "illustrationId": "li_hospital_recover",
      "dialogues": [
        {
          "id": "dlg_106",
          "speaker": "narrator",
          "speakerName": "",
          "text": "救护车及时赶到，静脉推注葡萄糖后李伯伯意识恢复。医生说幸亏处置得当、没有误吸，否则后果严重。李伯伯躺在病床上，第一次显得有些服软。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_107",
          "speaker": "elder",
          "speakerName": "李伯伯",
          "text": "（虚弱地）我这回……算是真栽了。原来'不服老'也得有个度。",
          "layer": "essential",
          "emotion": "humbled"
        },
        {
          "id": "dlg_108",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "危机有时是转机。这次急症，反而让他真正开始正视身体。接下来要补上糖尿病并发症预防这一课。",
          "layer": "essential",
          "emotion": "gentle"
        }
      ],
      "nextNode": "li_act3_d24_001",
      "isCheckpoint": true,
      "tags": [
        "recovery",
        "turning-point"
      ]
    },
    {
      "id": "li_act3_d24_001",
      "characterId": "li_bobo",
      "act": 3,
      "day": 24,
      "type": "choice",
      "scene": "living_room",
      "illustrationId": "li_foot_check_intro",
      "dialogues": [
        {
          "id": "dlg_109",
          "speaker": "narrator",
          "speakerName": "",
          "text": "出院回家第三天，李伯伯说脚底有点麻、走路像踩棉花。医生叮嘱过糖尿病要定期查足部，他一直没当回事。这次急症后，他愿意听了。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_110",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "脚麻、踩棉花感是糖尿病周围神经病变的早期信号。糖尿病足是严重并发症，但可以预防。怎么帮李伯伯建立足部自查习惯？",
          "layer": "essential",
          "emotion": "concerned"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "让他每天去医院做专业足检",
          "description": "专业检查最稳妥",
          "isCorrect": false,
          "effects": [
            {
              "type": "independence",
              "delta": -5,
              "reason": "过度依赖医疗"
            },
            {
              "type": "mood",
              "delta": -3,
              "reason": "每天跑医院太折腾"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act3_d24_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "每天去医院不现实，也会让李伯伯觉得'我成病人了'。糖尿病足预防的关键是日常自查，不是医院检查。",
            "explanation": "糖尿病足预防分两层：1.定期医院专科检查（每年1次，高危者每半年）；2.每日居家自查（老人自己能做）。日常自查才是核心，培养老人自主能力。"
          }
        },
        {
          "id": "choice_b",
          "text": "教他每天洗脚后用镜子照看脚底，检查有无破损",
          "description": "建立每日自查习惯",
          "isCorrect": true,
          "effects": [
            {
              "type": "health",
              "delta": 8,
              "reason": "早期发现足部问题"
            },
            {
              "type": "independence",
              "delta": 5,
              "reason": "自己能管理"
            },
            {
              "type": "trust",
              "delta": 5,
              "reason": "学到实用知识"
            }
          ],
          "spiritPowerChange": 10,
          "nextNode": "li_act3_d24_002",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "完美！用镜子照脚底=老人能独立完成的自查方法。既预防了并发症，又保住了他的自主权，正合独立值85的他。",
            "explanation": "糖尿病足每日自查要点：1.温水（≤37℃）洗脚后擦干尤其趾缝；2.用镜子检查脚底有无破损水泡；3.检查鞋内有无异物；4.修剪趾甲平剪勿过短；5.不用刀剪处理鸡眼。神经病变使老人感觉迟钝，视觉检查是关键。"
          }
        },
        {
          "id": "choice_c",
          "text": "告诉他脚麻正常，年纪大了都这样",
          "description": "忽视症状",
          "isCorrect": false,
          "effects": [
            {
              "type": "health",
              "delta": -6,
              "reason": "神经病变进展，糖尿病足风险升高"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act3_d24_002",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "脚麻不是'正常衰老'，是糖尿病神经病变！忽视它可能发展成糖尿病足溃疡，严重者截肢。",
            "explanation": "糖尿病足发展链：高血糖→周围神经病变（脚麻/踩棉花感）→感觉减退+血供差→小破损不自知→感染→溃疡→坏疽→截肢。早期干预可完全预防，忽视则不可逆。"
          }
        }
      ],
      "props": [
        {
          "propId": "foot_check_mirror",
          "layer": "display",
          "autoShow": true
        }
      ],
      "tags": [
        "choice",

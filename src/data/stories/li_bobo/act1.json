  "nodes": [
    {
      "id": "li_act1_d1_001",
      "characterId": "li_bobo",
      "act": 1,
      "day": 1,
      "type": "narrative",
      "scene": "living_room",
      "illustrationId": "li_meeting_spirit",
      "dialogues": [
        {
          "id": "dlg_001",
          "speaker": "narrator",
          "speakerName": "",
          "text": "清晨六点半，李伯伯已经穿戴整齐，智能手表显示昨晚睡眠7小时、心率68。客厅茶几上摊着昨天的体检报告，'糖尿病早期'几个字被他用笔圈了又圈。",
          "layer": "essential",
          "duration": 4500,
          "typingSpeed": 30
        },
        {
          "id": "dlg_002",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "你好呀！我是家庭守护精灵。从今天起，我会陪着你一起守护李伯伯。",
          "layer": "essential",
          "emotion": "cheerful",
          "lottieAnimation": "spirit_appear",
          "typingSpeed": 35
        },
        {
          "id": "dlg_003",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "李伯伯刚退休半年，身体硬朗、会用智能设备，可血糖有点偏高。他嘴上不认老，心里其实还没适应闲下来的日子。",
          "layer": "essential",
          "emotion": "gentle",
          "typingSpeed": 35
        }
      ],
      "nextNode": "li_act1_d1_002",
      "transition": {
        "enter": "fade-in",
        "illustrationTransition": "watercolor",
        "duration": 800
      },
      "isCheckpoint": true,
      "tags": ["intro", "tutorial"],
      "devNote": "开场节点，精灵登场介绍李伯伯"
    },
    {
      "id": "li_act1_d1_002",
      "characterId": "li_bobo",
      "act": 1,
      "day": 1,
      "type": "choice",
      "scene": "living_room",
      "illustrationId": "li_morning_checkup",
      "dialogues": [
        {
          "id": "dlg_004",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "李伯伯正准备量空腹血糖。你觉得作为子女，第一件事应该怎么开口？",
          "layer": "essential",
          "emotion": "curious"
        },
        {
          "id": "dlg_005",
          "speaker": "elder",
          "speakerName": "李伯伯",
          "text": "（摆弄着血糖仪）这玩意儿我自己会弄，你别老盯着我，我又不是七老八十。",
          "layer": "essential",
          "emotion": "defensive"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "直接要求他每天把血糖数据发给你",
          "description": "远程监控，确保按时测血糖",
          "isCorrect": false,
          "effects": [
            { "type": "trust", "delta": -8, "reason": "被监视感，抗拒被管" },
            { "type": "mood", "delta": -3, "reason": "不被信任的不快" },
            { "type": "independence", "delta": -2, "reason": "自主权被剥夺" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act1_d1_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "李伯伯独立值很高，最反感被当成'病人'管着。这样开口，他只会更抗拒。",
            "explanation": "对不愿承认变老的老人，命令式监控会触发防御心理，反而让他隐瞒真实数据。先建立信任，再谈管理。"
          }
        },
        {
          "id": "choice_b",
          "text": "和他聊聊退休后的感受，再顺势问血糖",
          "description": "先建立情感连接，再关心健康",
          "isCorrect": true,
          "effects": [
            { "type": "trust", "delta": 8, "reason": "被理解、被尊重" },
            { "type": "mood", "delta": 5, "reason": "情绪被关注" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "li_act1_d1_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "做得好！先关心他这个人，再关心他的血糖。信任值很低时，任何'管理'都行不通。",
            "explanation": "信任值是'时间货币'。对独立值高、信任值低的老人，倾听比说教更有效。先建立信任，健康建议才听得进去。"
          }
        },
        {
          "id": "choice_c",
          "text": "夸他智能手表用得好，请教他怎么设置健康提醒",
          "description": "以请教姿态拉近距离，顺带引导健康监测",
          "isCorrect": true,
          "effects": [
            { "type": "trust", "delta": 6, "reason": "被尊重、被需要" },
            { "type": "mood", "delta": 6, "reason": "成就感" },
            { "type": "independence", "delta": 3, "reason": "主动权在他手里" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "li_act1_d1_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "太聪明了！李伯伯数字生活度85%，他享受'被请教'的感觉。这样既保住了他的面子，又把健康监测变成了他自己想做的事。",
            "explanation": "对数字生活度高的老人，利用他擅长的科技作为切入点，比直接管教有效得多。让他做'老师'，他会更愿意配合。"
          }
        }
      ],
      "tags": ["choice", "tutorial", "trust"],
      "devNote": "第一个选择，教学信任值的重要性"
    },
    {
      "id": "li_act1_d1_003",
      "characterId": "li_bobo",
      "act": 1,
      "day": 1,
      "type": "dayEnd",
      "scene": "bedroom",
      "illustrationId": "li_night_rest",
      "dialogues": [
        {
          "id": "dlg_006",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "第一天结束啦。记住，李伯伯的难题不是'不会用科技'，而是'用科技否认衰老'。我们慢慢来。",
          "layer": "essential",
          "emotion": "proud"
        },
        {
          "id": "dlg_007",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "（精灵落在茶几上，望着那台还在记录数据的智能手表）明天的晨练，会有新的发现哦。",
          "layer": "emotional",
          "emotion": "encouraging",
          "typingSpeed": 40
        }
      ],
      "tags": ["day-end"],
      "devNote": "Day 1 结束节点"
    },
    {
      "id": "li_act1_d2_001",
      "characterId": "li_bobo",
      "act": 1,
      "day": 2,
      "type": "narrative",
      "scene": "park",
      "illustrationId": "li_morning_walk",
      "dialogues": [
        {
          "id": "dlg_008",
          "speaker": "narrator",
          "speakerName": "",
          "text": "清晨的公园，李伯伯快步走着，智能手表显示心率128——偏高了一些。回到家，他悄悄从口袋摸出一块绿豆糕，三两口吃完。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_009",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "嘘——我看到了。李伯伯晨练后偷吃了甜食，还以为没人发现呢。",
          "layer": "essential",
          "emotion": "playful"
        }
      ],
      "nextNode": "li_act1_d2_002",
      "isCheckpoint": true,
      "tags": ["blood-sugar", "setup"]
    },
    {
      "id": "li_act1_d2_002",
      "characterId": "li_bobo",
      "act": 1,
      "day": 2,
      "type": "choice",
      "scene": "kitchen",
      "illustrationId": "li_glucose_check",
      "dialogues": [
        {
          "id": "dlg_010",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "现在该测餐后两小时血糖了。李伯伯的血糖仪APP记录显示，最近一周数据忽高忽低。你怎么处理这个偷吃甜食的情况？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "当面揭穿他偷吃，没收所有甜食",
          "description": "严格管控饮食",
          "isCorrect": false,
          "effects": [
            { "type": "trust", "delta": -10, "reason": "被戳穿、被管束，丢面子" },
            { "type": "mood", "delta": -5, "reason": "羞恼" },
            { "type": "independence", "delta": -5, "reason": "自主权被夺" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act1_d2_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "当众揭穿会让李伯伯更叛逆，下次他会藏得更深。信任值本来就低，这样做只会雪上加霜。",
            "explanation": "对不愿承认变老的老人，羞辱式管控会彻底关闭沟通。他会表面答应、背后照吃，数据反而更不可靠。"
          }
        },
        {
          "id": "choice_b",
          "text": "装作没看见，等他自己血糖仪报警",
          "description": "不干预，让数据说话",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": -5, "reason": "血糖波动持续伤身" },
            { "type": "trust", "delta": -2, "reason": "没被真正关心" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act1_d2_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "血糖仪报警了他大概率会嫌烦关掉。放任不管，健康值会悄悄往下掉。",
            "explanation": "糖尿病早期是可控的，但'假装没事'正是李伯伯的问题所在。不干预=默认他可以继续否认，错过早期干预黄金期。"
          }
        },
        {
          "id": "choice_c",
          "text": "聊起'控糖也能吃甜的'，推荐低GI零食替代",
          "description": "给台阶下，用知识替代指责",
          "isCorrect": true,
          "effects": [
            { "type": "health", "delta": 5, "reason": "饮食逐步改善" },
            { "type": "trust", "delta": 6, "reason": "保住面子又被关心" },
            { "type": "mood", "delta": 4, "reason": "不用憋着嘴馋" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "li_act1_d2_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "漂亮！既没戳穿他的面子，又把'控糖'变成了'换种吃法'。李伯伯会觉得你是来帮忙的，不是来管他的。",
            "explanation": "糖尿病早期控糖≠完全戒糖。低GI食物（如坚果、无糖酸奶、少量黑巧）可解馋。给老人留台阶，比正面对抗有效。"
          }
        }
      ],
      "props": [
        {
          "propId": "glucose_meter_app",
          "layer": "display",
          "autoShow": true
        }
      ],
      "tags": ["choice", "blood-sugar", "diet"],
      "devNote": "血糖管理教学，糖尿病饮食"
    },
    {
      "id": "li_act1_d2_003",
      "characterId": "li_bobo",
      "act": 1,
      "day": 2,
      "type": "dayEnd",
      "scene": "living_room",
      "illustrationId": "li_evening_talk",
      "dialogues": [
        {
          "id": "dlg_011",
          "speaker": "elder",
          "speakerName": "李伯伯",
          "text": "（嘟囔）低GI……这词儿研究所那帮人说过。行吧，改天买点坚果尝尝。",
          "layer": "essential",
          "emotion": "reluctant"
        },
        {
          "id": "dlg_012",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "看，他嘴硬，但听进去了。明天该聊聊运动啦。",
          "layer": "emotional",

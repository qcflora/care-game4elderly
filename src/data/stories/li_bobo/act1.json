          "typingSpeed": 40
        }
      ],
      "tags": ["day-end"]
    },
    {
      "id": "li_act1_d3_001",
      "characterId": "li_bobo",
      "act": 1,
      "day": 3,
      "type": "narrative",
      "scene": "park",
      "illustrationId": "li_exercise_choice",
      "dialogues": [
        {
          "id": "dlg_013",
          "speaker": "narrator",
          "speakerName": "",
          "text": "李伯伯今天晨练格外卖力——快走四十分钟后又加了两组台阶跑，智能手表跳出'运动过量'提示，他随手划掉，'年轻人这强度算热身'。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_014",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "糖尿病早期需要规律运动，但'过量'反而会让血糖先升后降，还伤关节。怎么劝他把握好度？",
          "layer": "essential",
          "emotion": "concerned"
        }
      ],
      "nextNode": "li_act1_d3_002",
      "isCheckpoint": true,
      "tags": ["exercise", "setup"]
    },
    {
      "id": "li_act1_d3_002",
      "characterId": "li_bobo",
      "act": 1,
      "day": 3,
      "type": "choice",
      "scene": "park",
      "illustrationId": "li_heart_rate",
      "dialogues": [
        {
          "id": "dlg_015",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "李伯伯的手表显示心率峰值148，对66岁偏高。你打算怎么帮他调整运动强度？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "让他别运动了，在家歇着最安全",
          "description": "保守起见，减少运动",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": -5, "reason": "缺乏运动血糖控制变差" },
            { "type": "independence", "delta": -5, "reason": "被限制自由" },
            { "type": "mood", "delta": -4, "reason": "闷得慌" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act1_d3_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "糖尿病早期恰恰需要运动！完全不运动，血糖会更难控制。这是'因噎废食'。",
            "explanation": "糖尿病管理三驾马车：饮食、运动、药物。运动能提高胰岛素敏感性。关键是'适量'，不是'不动'。每周150分钟中等强度有氧最理想。"
          }
        },
        {
          "id": "choice_b",
          "text": "教他用'说话测试法'判断强度，能说话不能唱歌正好",
          "description": "科学方法，把判断权交给他",
          "isCorrect": true,
          "effects": [
            { "type": "health", "delta": 8, "reason": "运动强度合理，血糖改善" },
            { "type": "trust", "delta": 5, "reason": "学到有用知识" },
            { "type": "independence", "delta": 4, "reason": "自己能判断" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "li_act1_d3_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "太棒了！'说话测试法'不用看手表也能判断，正好满足李伯伯'我不靠仪器'的倔强。中等强度=能说话但不能唱歌。",
            "explanation": "中等强度运动判断法：运动时能完整说一句话但不能唱歌，约相当于最大心率的60-70%。对66岁，目标心率约90-105次/分。比死盯数字更易坚持。"
          }
        },
        {
          "id": "choice_c",
          "text": "建议他改打太极拳或快走，别再跑台阶",
          "description": "换低冲击运动，保护关节",
          "isCorrect": true,
          "effects": [
            { "type": "health", "delta": 6, "reason": "运动方式更安全" },
            { "type": "trust", "delta": 4, "reason": "建议合理" }
          ],
          "spiritPowerChange": 8,
          "nextNode": "li_act1_d3_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "好选择！太极拳、快走、游泳这些低冲击有氧，对糖尿病早期老人更友好，还不伤膝盖。",
            "explanation": "老年人关节退变，跑台阶、跳绳等高冲击运动易伤膝。推荐快走、太极、八段锦、游泳，每次30分钟、每周5次。"
          }
        }
      ],
      "props": [
        {
          "propId": "smartwatch_heart_rate",
          "layer": "display",
          "autoShow": true
        }
      ],
      "tags": ["choice", "exercise"],
      "devNote": "运动指导教学"
    },

    {
      "id": "li_act1_d4_001",
      "characterId": "li_bobo",
      "act": 1,
      "day": 4,
      "type": "narrative",
      "scene": "kitchen",
      "illustrationId": "li_breakfast_table",
      "dialogues": [
        {
          "id": "dlg_018",
          "speaker": "narrator",
          "speakerName": "",
          "text": "早餐桌上，老伴给李伯伯盛了满满一碗白米粥、两个肉包子，还有一碟腌菜。李伯伯吃得香，血糖仪却悄悄亮起红灯。",

    {
      "id": "li_act1_d4_002",
      "characterId": "li_bobo",
      "act": 1,
      "day": 4,
      "type": "choice",
      "scene": "kitchen",
      "illustrationId": "li_breakfast_choice",
      "dialogues": [
        {
          "id": "dlg_020",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "这顿早餐该怎么调整，既控糖又不让老伴难堪？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "直接说白粥升糖快，让老伴以后别熬了",
          "description": "明确指出问题",
          "isCorrect": false,
          "effects": [
            { "type": "mood", "delta": -6, "reason": "老伴心意被否定" },
            { "type": "trust", "delta": -3, "reason": "家庭气氛僵" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "li_act1_d4_003",
          "feedback": {

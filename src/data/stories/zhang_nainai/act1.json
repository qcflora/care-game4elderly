      "act": 1,
      "day": 4,
      "type": "choice",
      "scene": "bathroom",
      "illustrationId": "zhang_bath_choice",
      "dialogues": [
        {
          "id": "dlg_d4_3",
          "speaker": "elder",
          "speakerName": "张奶奶",
          "text": "我自己洗就行，你在外面等着就好。",
          "layer": "essential",
          "emotion": "polite"

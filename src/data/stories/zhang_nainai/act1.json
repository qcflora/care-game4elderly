  "nodes": [
    {
      "id": "zhang_act1_d1_001",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 1,
      "type": "narrative",
      "scene": "bedroom",
      "illustrationId": "zhang_morning_light",
      "dialogues": [
        {
          "id": "dlg_d1_1",
          "speaker": "narrator",
          "speakerName": "",
          "text": "清晨六点半，窗帘缝里透进一线光。张秀兰已经醒了，她侧过身，慢慢地把腿从被子里挪出来，动作很轻，像是怕吵醒隔壁房间的儿子。",
          "layer": "essential",
          "duration": 4500,
          "typingSpeed": 30
        },
        {
          "id": "dlg_d1_2",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "你好呀，我是家庭守护精灵。从今天起，我会陪在你身边，一起守护张奶奶——这位78岁的退休语文老师。",
          "layer": "essential",
          "emotion": "cheerful",
          "lottieAnimation": "spirit_appear",
          "typingSpeed": 35
        },
        {
          "id": "dlg_d1_3",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "她和儿子一家同住，有心脏病和骨质疏松。两年前跌倒过一次，从那以后她就很怕走路。最让我担心的是——她身体不舒服的时候，总是忍着不说。",
          "layer": "essential",
          "emotion": "gentle",
          "typingSpeed": 35
        },
        {
          "id": "dlg_d1_4",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "你看，她正准备起床呢。这个时候可得小心，老人起床太急容易头晕。你觉得应该怎么做？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "nextNode": "zhang_act1_d1_002",
      "transition": {
        "enter": "fade-in",
        "illustrationTransition": "watercolor",
        "duration": 800
      },
      "isCheckpoint": true,
      "tags": ["intro", "tutorial", "morning"],
      "devNote": "开场节点，精灵首次登场，介绍张奶奶背景"
    },
    {
      "id": "zhang_act1_d1_002",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 1,
      "type": "choice",
      "scene": "bedroom",
      "illustrationId": "zhang_getting_up",
      "dialogues": [
        {
          "id": "dlg_d1_5",
          "speaker": "elder",
          "speakerName": "张奶奶",
          "text": "（撑着床沿想站起来，动作有些发颤）没事没事，我自己能行……",
          "layer": "essential",
          "emotion": "strained"
        }
      ],
      "choices": [
        {
          "id": "zhang_act1_d1_002_a",
          "text": "直接扶住她胳膊，帮她坐起来站好",
          "description": "快速起身，避免她久坐受凉",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": 3, "reason": "减少了起身时间" },
            { "type": "independence", "delta": -8, "reason": "过度代劳，剥夺自理" },
            { "type": "mood", "delta": -3, "reason": "感到自己没用" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "zhang_act1_d1_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "嗯……你是好心，但张奶奶自己还能慢慢起身。直接代劳会让她觉得自己什么都做不了。而且起床太快反而容易头晕跌倒。",
            "explanation": "过度代劳降低独立值。老人起床应遵循「三个30秒」：醒后躺30秒、坐30秒、站30秒，预防体位性低血压。"
          }
        },
        {
          "id": "zhang_act1_d1_002_b",
          "text": "提醒她先坐30秒再站，在旁边护着但不搀扶",
          "description": "辅助而非替代",
          "isCorrect": true,
          "effects": [
            { "type": "health", "delta": 4, "reason": "预防体位性低血压" },
            { "type": "independence", "delta": 8, "reason": "鼓励自理" },
            { "type": "mood", "delta": 2, "reason": "被尊重的安心感" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "zhang_act1_d1_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "做得真好！让她自己起，你在旁边守着——这叫「辅助而非替代」。记住了吗？老人起床要「躺30秒、坐30秒、站30秒」。",
            "explanation": "体位性低血压预防：起床先坐30秒。辅助而非替代是照护的核心原则，既保证安全又维护自理能力。"
          }
        },
        {
          "id": "zhang_act1_d1_002_c",
          "text": "她说能行，那就让她自己起，先去准备早饭",
          "description": "尊重她的意愿",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": -5, "reason": "无人保护，跌倒风险" },
            { "type": "independence", "delta": 3, "reason": "自主行动" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "zhang_act1_d1_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "张奶奶有骨质疏松，又怕跌倒，完全没人看着很危险。她说「能行」往往是不想麻烦你——这正是她「忍着不说」的习惯。",
            "explanation": "完全不管会增加跌倒风险。正确做法是在旁保护但不代劳。要学会听懂老人「不用帮」背后的真实需要。"
          }
        }
      ],
      "props": [
        {
          "propId": "bedroom_nightlight",
          "layer": "display",
          "autoShow": true
        }
      ],
      "tags": ["choice", "tutorial", "morning", "fall-prevention"],
      "devNote": "第一个选择，教学体位性低血压与辅助非替代"
    },
    {
      "id": "zhang_act1_d1_003",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 1,
      "type": "dialogue",
      "scene": "bedroom",
      "illustrationId": "zhang_sitting_edge",
      "dialogues": [
        {
          "id": "dlg_d1_6",
          "speaker": "elder",
          "speakerName": "张奶奶",
          "text": "哎，坐一会儿再站起来好多了，头不那么晕了。谢谢你啊，孩子。",
          "layer": "essential",
          "emotion": "grateful"
        },
        {
          "id": "dlg_d1_7",
          "speaker": "narrator",
          "speakerName": "",
          "text": "她在床边坐稳，慢慢穿上那双软底布鞋，目光落在床头柜上那本翻旧了的硬抄本——那是她的血压记录本。",
          "layer": "emotional",
          "typingSpeed": 40
        }
      ],
      "nextNode": "zhang_act1_d1_004",
      "isCheckpoint": true
    },
    {
      "id": "zhang_act1_d1_004",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 1,
      "type": "dayEnd",
      "scene": "bedroom",
      "illustrationId": "zhang_night_rest",
      "dialogues": [
        {
          "id": "dlg_d1_8",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "第一天结束了！今天你学会了第一条：起床「躺、坐、站」各30秒。明天我们会遇到新的挑战——张奶奶的一堆药。",
          "layer": "essential",
          "emotion": "proud"
        },
        {
          "id": "dlg_d1_9",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "（精灵轻轻落在硬抄本上，像是在守护那些潦草的数字）她的世界很小，但每一个细节都值得被看见。",
          "layer": "emotional",
          "emotion": "gentle",
          "typingSpeed": 40
        }
      ],
      "tags": ["day-end"],
      "devNote": "Day 1 结束，伏笔：纸质血压记录本"
    },
    {
      "id": "zhang_act1_d2_001",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 2,
      "type": "narrative",
      "scene": "bedroom",
      "illustrationId": "zhang_dizzy_morning",
      "dialogues": [
        {
          "id": "dlg_d2_1",
          "speaker": "narrator",
          "speakerName": "",
          "text": "第二天清晨，张奶奶照旧醒了。今天她坐起来的时候，身子晃了一下，扶住了床头才稳住。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_d2_2",
          "speaker": "elder",
          "speakerName": "张奶奶",
          "text": "（低声）没事……就是起猛了，眼前有点花。",
          "layer": "essential",
          "emotion": "uneasy"
        },
        {
          "id": "dlg_d2_3",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "她又说「没事」了。但这可不是小事——头晕可能是体位性低血压，也可能是血压控制不好。你怎么处理？",
          "layer": "essential",
          "emotion": "concerned"
        }
      ],
      "nextNode": "zhang_act1_d2_002",
      "tags": ["morning", "fall-prevention"]
    },
    {
      "id": "zhang_act1_d2_002",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 2,
      "type": "choice",
      "scene": "bedroom",
      "illustrationId": "zhang_bp_check",
      "dialogues": [
        {
          "id": "dlg_d2_4",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "她坐稳了，但脸色不太好。接下来你打算怎么做？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "zhang_act1_d2_002_a",
          "text": "让她坐稳休息，询问头晕情况，等缓解后量血压",
          "description": "先观察评估再行动",
          "isCorrect": true,
          "effects": [
            { "type": "health", "delta": 8, "reason": "及时监测血压" },
            { "type": "trust", "delta": 3, "reason": "被认真对待" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "zhang_act1_d2_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "非常好！头晕时不能急着站，先坐着休息观察。等缓解后再量血压，才能判断是体位性低血压还是血压波动。她「忍着不说」，所以你要主动问。",
            "explanation": "体位性低血压处理：先坐稳休息，评估症状，必要时测量血压。主动询问是破解「忍着不说」的第一步。"
          }
        },
        {
          "id": "zhang_act1_d2_002_b",
          "text": "赶紧扶她躺回床上，让她再多睡会儿",
          "description": "让她休息恢复",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": 3, "reason": "暂时缓解" },
            { "type": "independence", "delta": -8, "reason": "过度保护" },
            { "type": "mood", "delta": -3, "reason": "感到被当成病人" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "zhang_act1_d2_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "让她躺回去看似安全，但没搞清楚头晕的原因，问题还在。而且她会觉得自己一不舒服就被按回床上，越来越不敢动。",
            "explanation": "过度保护会让独立值和心情值同时下降。正确做法是先评估原因，而非简单回避活动。"
          }
        },
        {
          "id": "zhang_act1_d2_002_c",
          "text": "让她慢慢站起来试试，看能不能走",
          "description": "测试她的状态",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": -5, "reason": "头晕时站立增加跌倒风险" },
            { "type": "trust", "delta": 1, "reason": "鼓励尝试" }
          ],
          "spiritPowerChange": 5,
          "nextNode": "zhang_act1_d2_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "头晕还没缓解就让她站，万一腿软摔了呢？她有骨质疏松，摔一下可不得了。先坐稳，等好了再说。",
            "explanation": "头晕未缓解时站立有跌倒风险。应遵循「躺、坐、站」节奏，确认缓解后再活动。"
          }
        }
      ],
      "props": [

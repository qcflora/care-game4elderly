    {
      "id": "zhang_act1_d3_001",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 3,
      "type": "narrative",
      "scene": "living_room",
      "illustrationId": "zhang_medicine_table",
      "dialogues": [
        {
          "id": "dlg_d3_1",
          "speaker": "narrator",
          "speakerName": "",
          "text": "早餐桌上摆着好几个药瓶。张奶奶的药不少——心脏病的、骨质疏松的，还有钙片。她眯着眼挨个看标签，有些吃力。",
          "layer": "essential",
          "duration": 4000,
          "typingSpeed": 30
        },
        {
          "id": "dlg_d3_2",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "今天的学习重点来了！张奶奶同时吃好几种药，每种吃药时间还不一样。有的空腹、有的餐后、有的睡前。我们得帮她把药盒分好类。",
          "layer": "essential",
          "emotion": "focused"
        },
        {
          "id": "dlg_d3_3",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "你看这个药盒，分成早、中、晚、睡前四格。你来帮她把药分进去吧——记住，有些药有特殊要求哦。",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "nextNode": "zhang_act1_d3_002",
      "props": [
        {
          "propId": "weekly_pill_box",
          "layer": "operate",
          "autoShow": true
        }
      ],
      "tags": ["medication", "tutorial"]
    },
    {
      "id": "zhang_act1_d3_002",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 3,
      "type": "choice",
      "scene": "living_room",
      "illustrationId": "zhang_pill_sorting",
      "dialogues": [
        {
          "id": "dlg_d3_4",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "阿司匹林肠溶片要空腹，美托洛尔要餐后，他汀类睡前吃，钙片餐后……还有一种阿仑膦酸钠，要求很特别。你会怎么分？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "zhang_act1_d3_002_a",
          "text": "按服药时间分四格，阿仑膦酸钠放晨起空腹格并标注「满杯水+直立30分钟」",
          "description": "严格按照每种药的要求分类",
          "isCorrect": true,
          "effects": [
            { "type": "health", "delta": 8, "reason": "科学用药" },
            { "type": "trust", "delta": 3, "reason": "认真负责" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "zhang_act1_d3_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "太棒了！阿仑膦酸钠必须晨起空腹用满杯水送服，服后保持直立30分钟，不然会刺激食道。你连这种细节都注意到了，张奶奶很安心。",
            "explanation": "服药时间分类：空腹/随餐/餐后/睡前。阿仑膦酸钠特殊要求：空腹、满杯水、服后直立30分钟，避免食道刺激。"
          }
        },
        {
          "id": "zhang_act1_d3_002_b",
          "text": "按早、晚两格简单分一下就好",
          "description": "大致分类",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": 4, "reason": "基本按时吃药" },
            { "type": "trust", "delta": 1, "reason": "有在帮忙" }
          ],
          "spiritPowerChange": 5,
          "nextNode": "zhang_act1_d3_003",
          "feedback": {
            "type": "neutral",
            "spiritDialogue": "方向对了，但分得太粗。阿仑膦酸钠和空腹药放一起，钙片和餐后药放一起，时间搞混了会影响药效。来，我教你仔细分。",
            "explanation": "药物分类要精确到空腹/随餐/餐后/睡前四类，混放会导致服药时间错误，影响疗效或增加副作用。"
          }
        },
        {
          "id": "zhang_act1_d3_002_c",
          "text": "把药瓶都摆着，让她每次自己拿",
          "description": "尊重她的自主",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": -5, "reason": "容易吃错或漏服" },
            { "type": "trust", "delta": -3, "reason": "感觉被敷衍" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "zhang_act1_d3_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "药瓶摆一堆，老人家眼神不好，很容易拿错或重复吃。用药安全可马虎不得，分好药盒才是负责任的做法。",
            "explanation": "外观相似的药物易混淆。应使用周药盒按时间分好，降低漏服、错服、重复服用的风险。"
          }
        }
      ],

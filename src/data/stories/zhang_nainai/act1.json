      "dialogues": [
        {
          "id": "dlg_d7_1",
          "speaker": "narrator",
          "speakerName": "",
          "text": "一周过去了。傍晚，张奶奶坐在窗边，夕阳把她花白的头发染成淡金色。她手里的硬抄本翻到了新的一页，血压记录工工整整。",
          "layer": "essential",
          "duration": 4500,
          "typingSpeed": 30
        },
        {
          "id": "dlg_d7_2",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "第一周结束了！来回顾一下。这一周你学会了：起床「三个30秒」、药盒分类、洗澡安全、血压记录、还有帮她克服跌倒恐惧。",
          "layer": "essential",
          "emotion": "proud"
        },
        {
          "id": "dlg_d7_3",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "最重要的原则是：辅助而非替代。张奶奶还能做的事，就让她自己做；你做的是保护和支持，不是替代。那接下来一周，你觉得最该关注什么？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "nextNode": "zhang_act1_d7_002",
      "tags": ["week-review", "checkpoint"]
    },
    {
      "id": "zhang_act1_d7_002",
      "characterId": "zhang_nainai",
      "act": 1,
      "day": 7,
      "type": "choice",
      "scene": "living_room",
      "illustrationId": "zhang_week_plan",
      "dialogues": [
        {
          "id": "dlg_d7_4",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "第二周的主题是「心声与平衡」。张奶奶最大的问题是「忍着不说」——身体不舒服她不说，心里有顾虑她也不说。你打算怎么应对？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "zhang_act1_d7_002_a",
          "text": "主动观察和询问，让她感到被关注，慢慢愿意开口",
          "description": "建立信任，破解沉默",
          "isCorrect": true,
          "effects": [
            { "type": "trust", "delta": 8, "reason": "被认真对待" },
            { "type": "mood", "delta": 3, "reason": "被关心的温暖" }
          ],
          "spiritPowerChange": 10,
          "nextNode": "zhang_act1_d7_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "说得好！她不是不想说，是怕给你添麻烦。你要做的是让她觉得「说出来不会被嫌烦」，这需要耐心和主动。信任是慢慢攒起来的。",
            "explanation": "破解「忍着不说」的关键：主动观察+耐心询问+不评判的倾听。信任值是时间货币，需要长期积累。"
          }
        },
        {
          "id": "zhang_act1_d7_002_b",
          "text": "重点盯用药和血压，身体好了自然心情好",
          "description": "以身体健康为优先",
          "isCorrect": false,
          "effects": [
            { "type": "health", "delta": 4, "reason": "关注身体健康" },
            { "type": "trust", "delta": 1, "reason": "有在照顾" }
          ],
          "spiritPowerChange": 5,
          "nextNode": "zhang_act1_d7_003",
          "feedback": {
            "type": "neutral",
            "spiritDialogue": "身体健康当然重要，但张奶奶的问题不只是身体。她忍着不说，你光盯数据发现不了。有时心情好了，身体反而跟着好。",
            "explanation": "照护不只是管理身体指标。心理支持和身体健康同样重要，甚至相互影响。忽视心理信号会导致心情值跌破阈值。"
          }
        },
        {
          "id": "zhang_act1_d7_002_c",
          "text": "全天陪护，寸步不离，确保她什么都跟我说",
          "description": "全程陪伴",
          "isCorrect": false,
          "effects": [
            { "type": "independence", "delta": -8, "reason": "过度保护" },
            { "type": "mood", "delta": -3, "reason": "感到被监视" }
          ],
          "spiritPowerChange": 0,
          "nextNode": "zhang_act1_d7_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "寸步不离听起来很用心，但张奶奶会觉得你在监视她，反而更不敢说了。她要的是「需要的时候你在」，不是「时时刻刻盯着」。",
            "explanation": "过度陪护会让老人感到压力和被监视，反而降低信任和心情。适当的空间和主动的关心，比全天候监视更有效。"
          }
        }
      ],
      "tags": ["choice", "week-review"]

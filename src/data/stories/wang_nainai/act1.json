    {
      "id": "wang_act1_d3_003",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 3,
      "type": "dayEnd",
      "scene": "living_room",
      "illustrationId": "wang_evening_quiet",
      "dialogues": [
        {
          "id": "dlg_020",
          "speaker": "elder",
          "speakerName": "王奶奶",
          "text": "（刘阿姨走后，轻声说）……谢谢你，孩子。老张走后，好久没跟人提起他了。",
          "layer": "essential",
          "emotion": "grateful"
        },
        {
          "id": "dlg_021",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "王奶奶今天流了眼泪，但这是疗愈的眼泪。她心里的结，需要慢慢解开。明天，有个和'热'有关的难题等着你呢。",
          "layer": "emotional",

    {
      "id": "wang_act1_d3_001",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 3,
      "type": "narrative",
      "scene": "living_room",
      "illustrationId": "wang_neighbor_visit",
      "dialogues": [
        {
          "id": "dlg_015",
          "speaker": "narrator",
          "speakerName": "",
          "text": "下午，楼下刘阿姨来串门。两人坐在沙发上，聊着小区里的新鲜事，笑声不断。",
          "layer": "essential",
          "typingSpeed": 30,
          "duration": 4000
        },
        {
          "id": "dlg_016",
          "speaker": "narrator",
          "speakerName": "",
          "text": "聊着聊着，刘阿姨叹了口气：'秀英啊，老张走了也有三年了吧？你一个人可真不容易。'",
          "layer": "essential",
          "typingSpeed": 30,
          "duration": 4000
        },
        {
          "id": "dlg_017",
          "speaker": "elder",
          "speakerName": "王奶奶",
          "text": "（眼眶微红，低下头）……是啊，三年了。有时候夜里醒来，还觉得他在隔壁房间咳嗽。",
          "layer": "essential",
          "emotion": "sad",
          "typingSpeed": 40
        },
        {
          "id": "dlg_018",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "王奶奶情绪低落了。老伴是她心里最柔软的地方，也是她不愿触碰的伤口。这个时候，你怎么做？",
          "layer": "essential",
          "emotion": "gentle"
        }
      ],
      "nextNode": "wang_act1_d3_002",
      "isCheckpoint": true,
      "tags": [
        "emotion",
        "grief",
        "setup"
      ]
    },
    {
      "id": "wang_act1_d3_002",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 3,
      "type": "choice",
      "scene": "living_room",
      "illustrationId": "wang_grief_choice",
      "dialogues": [

            },
            {
              "type": "mood",
              "delta": -5,
              "reason": "悲伤被压抑"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "wang_act1_d3_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "王奶奶勉强笑了笑，但眼神黯淡下去。她觉得你连听她说完的耐心都没有，心里的门又关紧了一些。",
            "explanation": "对丧偶老人，悲伤是正常的情感，需要被接纳而非回避。强行转移话题会让她感到被否定，长期压抑悲伤可能导致抑郁。"
          }
        },
        {
          "id": "choice_b",
          "text": "安静地坐在旁边，让她把想说的话说完",
          "description": "陪伴倾听，不急于打断",
          "isCorrect": true,
          "effects": [
            {
              "type": "trust",
              "delta": 8,
              "reason": "被理解和接纳"

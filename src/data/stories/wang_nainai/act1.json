  "nodes": [
    {
      "id": "wang_act1_d1_001",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 1,
      "type": "narrative",
      "scene": "living_room",
      "illustrationId": "wang_meeting_spirit",
      "dialogues": [
        {
          "id": "dlg_001",
          "speaker": "narrator",
          "speakerName": "",
          "text": "清晨的阳光透过老旧的纱帘，洒在王奶奶家的客厅里。家具都是二十多年前的款式，擦得一尘不染。窗台上几盆绿萝长得正好，那是王奶奶每天精心照料的心血。",
          "layer": "essential",
          "typingSpeed": 30,
          "duration": 4500
        },
        {
          "id": "dlg_002",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "你好呀！我是家庭守护精灵，从今天起，我会陪你一起照顾王奶奶。",
          "layer": "essential",
          "emotion": "cheerful",
          "typingSpeed": 35,
          "lottieAnimation": "spirit_appear"
        },
        {
          "id": "dlg_003",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "王奶奶今年七十二岁，退休小学教师，独居在这栋老小区的三楼。她善良、要强、节俭，凡事都喜欢自己来。三年前，老伴去世了，儿子在北京工作，平时难得回来。",
          "layer": "essential",
          "emotion": "gentle",
          "typingSpeed": 35
        },
        {
          "id": "dlg_004",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "她患有高血压，每天早上都要服用降压药。照护她的关键，是在关心她的同时，维护她那颗要强的心。",
          "layer": "essential",
          "emotion": "thoughtful",
          "typingSpeed": 35
        }
      ],
      "nextNode": "wang_act1_d1_002",
      "transition": {
        "enter": "fade-in",
        "illustrationTransition": "watercolor",
        "duration": 800
      },
      "isCheckpoint": true,
      "tags": [
        "intro",
        "tutorial"
      ],
      "devNote": "开场节点，精灵首次登场，介绍王奶奶背景"
    },
    {
      "id": "wang_act1_d1_002",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 1,
      "type": "choice",
      "scene": "living_room",
      "illustrationId": "wang_morning_meds",
      "dialogues": [
        {
          "id": "dlg_005",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "早上八点，王奶奶拿起茶几上的降压药盒。你注意到药盒上的标签有些磨损。作为子女，你觉得该怎么做？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "直接帮她取出药片，倒好温水递给她",
          "description": "快速完成，确保按时服药",
          "isCorrect": false,
          "effects": [
            {
              "type": "health",
              "delta": 3,
              "reason": "按时服药"
            },
            {
              "type": "independence",
              "delta": -8,
              "reason": "过度代劳，剥夺自理能力"
            },
            {
              "type": "trust",
              "delta": -5,
              "reason": "伤自尊，感到被当成病人"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "wang_act1_d1_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "王奶奶接过水杯，眉头微微皱了一下。她自己能做的事被代劳了，心里不是滋味。",
            "explanation": "过度代劳会降低老人的独立值和信任值。在能力范围内，应鼓励老人自己完成日常事务，维护其尊严。"
          }
        },
        {
          "id": "choice_b",
          "text": "把药盒递给她，让她自己取药",
          "description": "尊重奶奶的自理能力",
          "isCorrect": true,
          "effects": [
            {
              "type": "health",
              "delta": 5,
              "reason": "按时服药"
            },
            {
              "type": "independence",
              "delta": 5,
              "reason": "鼓励自理"
            },
            {
              "type": "trust",
              "delta": 4,
              "reason": "尊重老人"
            }
          ],
          "spiritPowerChange": 5,
          "nextNode": "wang_act1_d1_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "不错！让奶奶自己取药，维护了自理能力。不过如果先核对一下剂量，会更安全哦。",
            "explanation": "鼓励自理是照护的基本原则，但用药安全同样重要。最佳做法是既让她参与，又帮她把关。"
          }
        },
        {
          "id": "choice_c",
          "text": "先拿起药盒，仔细查看标签上的名称和剂量",
          "description": "认真核对用药信息",
          "isCorrect": true,
          "skillCheck": {
            "skillId": "medication_basic",
            "requiredLevel": 1,
            "disableOnFail": false,
            "failureMessage": "你对用药管理还不够了解，但也可以尝试。"
          },
          "effects": [
            {
              "type": "health",
              "delta": 8,
              "reason": "准确用药，安全第一"
            },
            {
              "type": "trust",
              "delta": 6,
              "reason": "细心可靠"
            }
          ],
          "spiritPowerChange": 15,
          "nextNode": "wang_act1_d1_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "太棒了！用药前核对标签和剂量是基本的安全准则。王奶奶看到你这么细心，心里踏实多了。",
            "explanation": "老年人用药安全至关重要。核对药名、剂量、有效期，是防止用药错误的第一道防线。"
          }
        }
      ],
      "props": [
        {
          "propId": "medicine_box",
          "layer": "operate",
          "autoShow": true
        }
      ],
      "tags": [
        "medication",
        "choice",
        "tutorial"
      ],
      "devNote": "第一个选择节点，核心教学点：用药前核对剂量"
    },
    {
      "id": "wang_act1_d1_003",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 1,
      "type": "dayEnd",
      "scene": "bedroom",
      "illustrationId": "wang_night_rest",
      "dialogues": [
        {
          "id": "dlg_006",
          "speaker": "elder",
          "speakerName": "王奶奶",
          "text": "我自己还能弄这些呢。不过……你今天的做法，我记下了。",
          "layer": "essential",
          "emotion": "grateful"
        },
        {
          "id": "dlg_007",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "第一天结束啦！王奶奶虽然嘴上不说，但她注意到了你的细心和尊重。",
          "layer": "essential",
          "emotion": "proud"
        },
        {
          "id": "dlg_008",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "记住，王奶奶最需要的是被尊重、被需要的感觉。明天，新的挑战在等着你呢。",
          "layer": "emotional",
          "emotion": "encouraging",
          "typingSpeed": 40
        }
      ],
      "tags": [
        "day-end"
      ],
      "devNote": "Day 1 结束节点"
    },
    {
      "id": "wang_act1_d2_001",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 2,
      "type": "narrative",
      "scene": "living_room",
      "illustrationId": "wang_morning_market",
      "dialogues": [
        {
          "id": "dlg_009",
          "speaker": "narrator",
          "speakerName": "",
          "text": "早上七点半，王奶奶拎着布袋子准备出门。楼下菜市场的青菜比超市便宜两块，她每周二、五都要去。",
          "layer": "essential",
          "typingSpeed": 30,
          "duration": 4000
        },
        {
          "id": "dlg_010",
          "speaker": "narrator",
          "speakerName": "",
          "text": "但菜市场来回要爬三楼楼梯，还要提五六斤的蔬菜。她最近血压不太稳，提重物很危险。",
          "layer": "essential",
          "typingSpeed": 30,
          "duration": 4000
        },
        {
          "id": "dlg_011",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "王奶奶要去买菜了。高血压老人提重物容易导致血压骤升，甚至诱发心脑血管意外。怎么帮她？",
          "layer": "essential",
          "emotion": "concerned"
        }
      ],
      "nextNode": "wang_act1_d2_002",
      "isCheckpoint": true,
      "tags": [
        "daily-life",
        "setup"
      ]
    },
    {
      "id": "wang_act1_d2_002",
      "characterId": "wang_nainai",
      "act": 1,
      "day": 2,
      "type": "choice",
      "scene": "street",
      "illustrationId": "wang_market_choice",
      "dialogues": [
        {
          "id": "dlg_012",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "王奶奶执意要去买菜。你打算怎么处理这个 situation？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "直接帮她买好菜送过来",
          "description": "代劳购买，省力省心",
          "isCorrect": false,
          "effects": [
            {
              "type": "independence",
              "delta": -8,
              "reason": "剥夺自主权"
            },
            {
              "type": "trust",
              "delta": -3,
              "reason": "感到被当成无用的人"
            },
            {
              "type": "mood",
              "delta": -3,
              "reason": "失去生活掌控感"
            }
          ],
          "spiritPowerChange": 0,
          "nextNode": "wang_act1_d2_003",
          "feedback": {
            "type": "incorrect",
            "spiritDialogue": "王奶奶看到你买来的菜，脸色沉了下来：'我自己能买，不用你操心。'她把菜收进冰箱，一天都没怎么说话。",
            "explanation": "对自尊心强、节俭的老人，直接代劳买菜会让她觉得自己'没用了'。买菜不仅是家务，更是她保持社会连接和自主权的方式。"
          }
        },
        {
          "id": "choice_b",
          "text": "陪她一起去菜市场，帮她提东西",
          "description": "陪伴购买，既保安全又维护自主",
          "isCorrect": true,
          "effects": [
            {
              "type": "health",
              "delta": 5,
              "reason": "避免提重物，降低风险"
            },
            {
              "type": "independence",
              "delta": 3,
              "reason": "自己做主选购"
            },
            {
              "type": "trust",
              "delta": 5,
              "reason": "贴心陪伴"
            },
            {
              "type": "mood",
              "delta": 3,
              "reason": "有人陪伴的高兴"
            }
          ],
          "spiritPowerChange": 10,
          "nextNode": "wang_act1_d2_003",
          "feedback": {
            "type": "correct",
            "spiritDialogue": "好办法！王奶奶挑菜时眼睛发亮，还跟摊主聊起哪家西红柿最新鲜。你帮她提东西，她既省了力，又保住了面子。",
            "explanation": "陪伴是最贴心的照护。对独居老人，一起去菜市场不仅是安全考量，更是情感交流的机会。既维护了她的自主权，又暗中保障了安全。"
          }
        },
        {
          "id": "choice_c",
          "text": "耐心教她用智能手机在网上买菜，送货上门",
          "description": "教新技能，方便又省力",
          "isCorrect": true,
          "effects": [
            {
              "type": "independence",
              "delta": 6,
              "reason": "学会新技能"
            },
            {
              "type": "trust",
              "delta": 4,
              "reason": "耐心教导"

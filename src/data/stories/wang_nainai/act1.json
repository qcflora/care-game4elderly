          "id": "dlg_019",
          "speaker": "spirit",
          "speakerName": "小精灵",
          "text": "王奶奶的眼眶红了。面对她的悲伤，你选择怎么做？",
          "layer": "essential",
          "emotion": "curious"
        }
      ],
      "choices": [
        {
          "id": "choice_a",
          "text": "赶紧转移话题，聊点轻松的事",
          "description": "避免她继续难过",
          "isCorrect": false,
          "effects": [
            {
